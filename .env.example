# ── SmileCare Dental Clinic – Backend Environment Variables ──

# Groq API Key (required – used for Llama 3.3 70B LLM)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Deepgram API Key (required – used for Nova-3 STT + Aura TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# MongoDB Connection String (required)
MONGO_URI=mongodb://localhost:27017

# ── Optional / commented-out providers ──────────────────────

# Google Gemini API Key (uncomment to use Gemini LLM backend)
# GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (not currently used)
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ElevenLabs API Key (uncomment to use ElevenLabs TTS backend)
# ELEVEN_API_KEY=sk_your_elevenlabs_api_key_here
